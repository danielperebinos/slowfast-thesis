# Dashboard environment variables. Copy to .env if you want docker compose
# to load them automatically; otherwise export them in your shell.

# Port the Streamlit server binds to on the host. Must not collide with the
# MLflow stack (5432, 9000, 9001, 5000). 8501 is Streamlit's default.
DASHBOARD_PORT=8501

# Logger level for the dashboard. DEBUG is verbose but matches the plan.
DASHBOARD_LOG_LEVEL=DEBUG

# Read-only roots (absolute paths inside the container, or relative on host).
# Keep these read-only — the dashboard must NEVER write to experiments/ or AVA/.
PROJECT_ROOT=/workspace
MODEL_ROOT=/workspace/experiments
VIDEO_ROOT=/workspace/AVA

# Informational only — the dashboard does not write to MLflow.
MLFLOW_TRACKING_URI=http://host.docker.internal:5000
